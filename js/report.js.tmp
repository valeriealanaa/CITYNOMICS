function setText(id, value) {
  const element = document.getElementById(id);
  if (element) {
    element.textContent = value;
  }
}

document.addEventListener("DOMContentLoaded", () => {
  const hasState = typeof loadCityState === "function" ? loadCityState() : false;
  const emptyState = document.getElementById("reportEmpty");
  const reportContent = document.getElementById("reportContent");

  if (!hasState) {
    if (emptyState) emptyState.classList.remove("hidden");
    if (reportContent) reportContent.classList.add("hidden");
    return;
  }

  if (reportContent) {
    reportContent.classList.remove("hidden");
  }

  const current = {
    economy: Number(cityState.economy || 0),
    environment: Number(cityState.environment || 0),
    jobs: Number(cityState.jobs || 0),
    happiness: Number(cityState.happiness || 0),
    infrastructure: Number(cityState.infrastructure || 0)
  };

  const earningRate = Number(cityState.earningRate || 0);
  const earningRateScore = earningRate * 0.6;
  const investmentPerformance = clampScore(50 + earningRateScore + (current.economy - 50) / 2);
  const socialEnvironmental = clampScore((current.environment + current.happiness + current.jobs) / 3);

  const journeyEntries = Array.isArray(cityState.journey) ? cityState.journey : [];
  const reasons = journeyEntries.map((item) => item.reason || "");
  const avgLength = reasons.length ? reasons.reduce((sum, text) => sum + text.length, 0) / reasons.length : 0;
  const keywordHits = reasons.filter((text) => /lingkungan|sosial|risiko|masyarakat|kerja|dampak/i.test(text)).length;
  const decisionQuality = clampScore(Math.min(70, avgLength / 1.4) + (reasons.length ? (keywordHits / reasons.length) * 30 : 0));
  const cityDevelopment = clampScore((current.infrastructure + current.economy) / 2);
  const finalScore = Math.round((investmentPerformance + cityDevelopment + socialEnvironmental + decisionQuality) / 4);
  const totalBuy = journeyEntries.filter((item) => item.action === "BUY").length;
  const totalSell = journeyEntries.filter((item) => item.action === "SELL").length;
  const totalHold = journeyEntries.filter((item) => item.action === "HOLD").length;
  const totalDecisions = journeyEntries.length;
  const buyPct = totalDecisions ? Math.round((totalBuy / totalDecisions) * 100) : 0;
  const sellPct = totalDecisions ? Math.round((totalSell / totalDecisions) * 100) : 0;
  const holdPct = totalDecisions ? Math.round((totalHold / totalDecisions) * 100) : 0;

  setText("beforeStats", "🏚️ 🌫️ 👷⬇️ 🙁");
  setText("afterStats", describeCityEmoji(current));
  setText("finalScore", `${finalScore} / 100`);
  setText("availableFund", formatRupiah(Number(cityState.availableFund || 0)));
  setText("investedFund", formatRupiah(Number(cityState.investedFund || 0)));
  setText("totalAsset", formatRupiah(Number(cityState.totalAsset || 0)));
  setText("earningRate", `${earningRate.toFixed(2)}%`);
  setText("returnVal", `${earningRate.toFixed(2)}%`);
  setText("cityRank", cityState.rank || "-");
  setText("buyCount", `${totalBuy}`);
  setText("sellCount", `${totalSell}`);
  setText("holdCount", `${totalHold}`);
  setText("buyPct", `${buyPct}%`);
  setText("sellPct", `${sellPct}%`);
  setText("holdPct", `${holdPct}%`);

  const componentScores = document.getElementById("componentScores");
  if (componentScores) {
    componentScores.innerHTML = [
      ["Investment Performance", investmentPerformance],
      ["City Development", cityDevelopment],
      ["Social & Environmental Impact", socialEnvironmental],
      ["Decision Quality", decisionQuality]
    ].map(([label, value]) => `
      <div>
        <div class="mb-2 flex justify-between text-sm font-black"><span>${label}</span><span>${value}/100</span></div>
        <div class="progress"><span style="width: ${value}%"></span></div>
      </div>
    `).join("");
  }

  const aiSummary = document.getElementById("aiSummary");
  if (aiSummary) {
    aiSummary.textContent = buildAiSummary(finalScore, current, journeyEntries.length);
  }

  const journeyContainer = document.getElementById("journeyList") || document.getElementById("finalJourney");
  if (journeyContainer) {
    journeyContainer.innerHTML = journeyEntries.length
      ? journeyEntries.map((item) => `
          <div class="mb-3 rounded-[10px] bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between gap-3">
              <div>
                <strong>${item.action || "DECISION"} ${item.company || ""}${item.percentage ? ` (${item.percentage}%)` : ""}</strong>
                <p class="mt-2 text-sm font-semibold text-slate-600">Investasi: ${formatRupiah(Number(item.amount || 0))}</p>
                ${item.action === "SELL" ? `<p class="mt-1 text-sm font-semibold text-emerald-600">Profit: ${formatRupiah(Number(item.profit || 0))}</p>` : ""}
              </div>
              <span class="text-xs font-black text-emerald-600">Bulan ${item.month || "-"}</span>
            </div>
            <p class="mt-2 text-sm font-semibold leading-6 text-slate-500">${item.reason || "Tidak ada alasan tercatat."}</p>
            ${item.note ? `<p class="mt-2 text-xs font-bold text-emerald-700">Catatan AI: ${item.note}</p>` : ""}
          </div>
        `).join("")
      : `<p class="text-sm font-semibold text-slate-500">Belum ada riwayat keputusan.</p>`;
  }
});

function describeCityEmoji(stats) {
  const buildings = stats.infrastructure >= 70 ? "🏙️🏙️" : stats.infrastructure >= 45 ? "🏢🏢" : "🏚️";
  const green = stats.environment >= 70 ? "🌳🌳🌳" : stats.environment >= 45 ? "🌳🌳" : "🌫️";
  const mood = stats.happiness >= 70 ? "😊😊😊" : stats.happiness >= 45 ? "😊" : "🙁";
  return `${buildings} ${green} ${mood}`;
}

function buildAiSummary(score, stats, decisionCount) {
  const roi = Number(cityState.earningRate || 0).toFixed(2);
  const rank = cityState.rank || "-";

  if (Number(cityState.earningRate || 0) >= 20) {
    return `
Selama simulasi, kelompokmu berhasil memperoleh ROI sebesar ${roi}% dengan predikat ${rank}.
Strategi investasi yang diterapkan mampu meningkatkan nilai aset kota sekaligus menjaga pembangunan kota tetap stabil.
Jumlah keputusan investasi yang diambil sebanyak ${decisionCount} keputusan.
`;
  }

  if (Number(cityState.earningRate || 0) >= 10) {
    return `
Kelompokmu memperoleh ROI sebesar ${roi}% dengan predikat ${rank}.
Strategi investasi sudah cukup baik, namun masih terdapat peluang untuk meningkatkan keuntungan melalui pemilihan sektor yang lebih tepat pada setiap event ekonomi.
`;
  }

  return `
ROI investasi kelompok masih sebesar ${roi}% dengan predikat ${rank}.
Cobalah mengevaluasi kembali keputusan BUY, SELL, dan HOLD agar investasi dapat memberikan keuntungan yang lebih optimal pada simulasi berikutnya.
`;
}